# NodeWeaver Environment Configuration
# Copy this file to .env and customize the values

# ──────────────────────────────────────────────
# Core (required)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://rag_user:rag_pass@localhost:5432/nodeweaver
SESSION_SECRET=your-secret-key-change-this-in-production

# ──────────────────────────────────────────────
# AxTask integration — NodeWeaver side
# ──────────────────────────────────────────────
# Shared API key validated via X-API-Key header.
# Leave unset to disable auth (development only).
# NODEWEAVER_API_KEY=change-me-to-a-strong-random-string

# Comma-separated allowed CORS origins. Defaults to * when unset.
# NODEWEAVER_ALLOWED_ORIGINS=https://app.axtask.com,http://localhost:3000

# URL NodeWeaver POSTs topic-emergence webhook events to (AxTask side).
# Leave unset to disable webhooks.
# AXTASK_WEBHOOK_URL=https://api.axtask.com/webhooks/nodeweaver

# ──────────────────────────────────────────────
# AxTask integration — AxTask side (reference)
# These vars are consumed by the TypeScript client, not NodeWeaver itself.
# ──────────────────────────────────────────────
# NODEWEAVER_BASE_URL=http://localhost:5000
# NODEWEAVER_API_KEY=change-me-to-a-strong-random-string

# ──────────────────────────────────────────────
# RAG Engine
# ──────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# ──────────────────────────────────────────────
# Topic Detection Thresholds
# ──────────────────────────────────────────────
CONVERGENCE_THRESHOLD=0.7
MIN_CLUSTER_SIZE=3
COHERENCE_THRESHOLD=0.6

# ──────────────────────────────────────────────
# API
# ──────────────────────────────────────────────
MAX_INPUT_LENGTH=10000

# Maximum number of /api/v1/* requests allowed per IP per minute.
# Exceeding this returns HTTP 429 with a Retry-After header.
# RATE_LIMIT_PER_MINUTE=100

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Optional extras
# ──────────────────────────────────────────────
# OPENAI_API_KEY=your-openai-api-key
# REDIS_URL=redis://localhost:6379/0
# SENTRY_DSN=your-sentry-dsn
