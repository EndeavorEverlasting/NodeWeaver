#!/usr/bin/env sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

# Only sync deps when dependency manifests changed in the pull/merge.
CHANGED_FILES=""
if git rev-parse --verify ORIG_HEAD >/dev/null 2>&1; then
  CHANGED_FILES="$(git diff --name-only ORIG_HEAD HEAD || true)"
fi

case "$CHANGED_FILES" in
  *pyproject.toml*|*uv.lock*|*requirements.txt*|*requirements-dev.txt*)
    SHOULD_SYNC=1
    ;;
  *)
    SHOULD_SYNC=0
    ;;
esac

if [ "$SHOULD_SYNC" -eq 0 ]; then
  exit 0
fi

if command -v python3 >/dev/null 2>&1; then
  python3 scripts/sync_dependencies.py --with-dev --auto || true
elif command -v python >/dev/null 2>&1; then
  python scripts/sync_dependencies.py --with-dev --auto || true
elif command -v py >/dev/null 2>&1; then
  py -3 scripts/sync_dependencies.py --with-dev --auto || true
else
  echo "[deps-sync] Python 3 was not found. Run dependency sync manually." >&2
fi
